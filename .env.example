# Image
IMAGE_SIZE=32
REQUEST_TIMEOUT_SECONDS=6

# Spotify (obrigatorio para ativar o widget Spotify)
SPOTIPY_CLIENT_ID=
SPOTIPY_CLIENT_SECRET=
SPOTIPY_REDIRECT_URI=http://localhost:8888/callback
SPOTIFY_REFRESH_TOKEN=
SPOTIFY_ACCESS_TOKEN=

# Book widget
BOOK_STATE_PATH=data/current_book.json

# Skoob sync
# Ativa sincronizacao automatica do livro em leitura durante chamadas ao /screen
SKOOB_SYNC_ENABLED=false
SKOOB_SYNC_INTERVAL_SECONDS=300

# Modo 1 (publico): scraping do perfil
# Ex.: https://www.skoob.com.br/pt/profile/ricardosouza
SKOOB_PROFILE_URL=

# Modo 2 (privado): API interna do Skoob (precisa de cookie de sessao)
# Dica: user_id vem da URL /v1/bookcase/books/<user_id>/... no Network do navegador
# Dica: se nao achar no Network, deixe vazio que o backend tenta inferir pelo profile + cookie
SKOOB_USER_ID=
# Dica: copie o header Cookie completo da mesma request
SKOOB_AUTH_COOKIE=

# Tipos de estante tratados como "lendo" na API interna (default: 2)
SKOOB_READING_TYPES=2
